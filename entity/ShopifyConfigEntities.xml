<?xml version="1.0" encoding="UTF-8"?>
<entities xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/entity-definition-3.xsd">

    <entity entity-name="ShopifyAuthConfig" package="darpan.shopify" short-alias="shopifyAuthConfig" use="configuration">
        <description>Tenant-owned Shopify Admin API authentication and read-capability settings.</description>
        <field name="shopifyAuthConfigId" type="id" is-pk="true"/>
        <field name="description" type="text-medium"/>
        <field name="companyUserGroupId" type="id" cannot-be-null="true"/>
        <field name="createdByUserId" type="id"/>
        <field name="shopApiUrl" type="text-long" cannot-be-null="true"/>
        <field name="apiVersion" type="text-short" cannot-be-null="true"/>
        <field name="timeZone" type="text-short" default="'UTC'"/>
        <field name="accessToken" type="text-long" encrypt="true"/>
        <field name="isActive" type="text-indicator" default="'Y'"/>
        <field name="canReadOrders" type="text-indicator" default="'N'"/>

        <relationship type="one" title="Company" related="moqui.security.UserGroup" short-alias="company">
            <key-map field-name="companyUserGroupId" related-field-name="userGroupId"/>
        </relationship>
    </entity>

</entities>
